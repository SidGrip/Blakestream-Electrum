# Blakestream ElectrumX server — environment template.
#
# Copy to `.env` next to docker-compose.yml (or in your DEPLOY_DIR) and edit.
# `deploy.sh` autoloads the first `.env` it finds in $PWD, $DEPLOY_DIR, or
# this directory. Variables here also override defaults in `deploy.sh` and
# in `deploy-electrumx.py` (via the wrapper).
#
# Anything left blank uses the documented default. Required values are marked.

# ---- Identity ----------------------------------------------------------------

# Public hostname clients connect to (REPORT_SERVICES). Used by deploy.sh to
# locate the Let's Encrypt cert lineage and to name the renewal hook.
# REQUIRED for any SSL deploy.
REPORT_HOST=

# ---- Daemon plumbing ---------------------------------------------------------

# Where ElectrumX reaches the coin daemons when explicit DAEMON_URL_<COIN>
# values are used. The generated compose uses network_mode: host, so
# 127.0.0.1 reaches native daemons bound to the host loopback.
DAEMON_HOST=127.0.0.1

# ---- Deployment layout -------------------------------------------------------

# Directory that holds the generated docker-compose.yml, the per-coin db/
# subdirs, and the ssl/ mount. Relative paths are resolved against PWD by
# deploy.sh.
DEPLOY_DIR=./deploy

# Add this value to every Electrum TCP/SSL/admin port. Keep 0 for production.
# Use a non-zero value for staging tests on hosts where canonical ports are in
# use. Example: 12000 makes BLC TCP 62001.
PORT_OFFSET=0

# 1 = have deploy.sh add the generated public Electrum TCP/SSL ports to ufw.
# RPC/admin ports are loopback-only and are not opened.
OPEN_FIREWALL=0

# ---- Image -------------------------------------------------------------------

# The image deploy.sh pulls (or builds, if BUILD_LOCAL=1). Override only when
# pinning a fork or a non-default tag.
IMAGE_TAG=sidgrip/electrumx-blakestream:25.2

# 1 = build locally via ../build-electrumx.sh --smoke --no-push instead of
# pulling. Useful when you have local patches or no registry access.
BUILD_LOCAL=0

# ---- Runtime ------------------------------------------------------------------

# Fee fallback for chains whose daemons return -1 from `estimatefee`.
# ElectrumX returns 500 to wallets if no fallback is set on such chains.
# The :25.2 image honours this env var; harmless to set on forks that ignore it.
ELECTRUMX_DEFAULT_FEE_BTC_KVB=0.00002

# Container user for copied TLS key ownership. The stock 25.2 image runs as
# root, so root ownership is correct. If you build a non-root image, set these
# to that container uid/gid so privkey.pem is readable inside the container.
ELECTRUMX_UID=0
ELECTRUMX_GID=0

# ---- TLS ----------------------------------------------------------------------

# Source directory for Let's Encrypt cert files. Leave blank to use the
# canonical certbot path: /etc/letsencrypt/live/${REPORT_HOST}
# deploy.sh copies fullchain.pem + privkey.pem from here to ${DEPLOY_DIR}/ssl/.
CERT_DIR=

# ---- Per-coin daemon URLs (REQUIRED if upstream-discovery fails) -------------
#
# Form: http://USER:PASS@${DAEMON_HOST}:<rpc-port>
#
# Leave blank to let deploy-electrumx.py auto-discover from each coin's local
# config (~/.<coin>/<coin>.conf) or from running Docker containers. Fill these
# in only when discovery cannot find a daemon (e.g. non-standard datadir).

DAEMON_URL_BLC=
DAEMON_URL_BBTC=
DAEMON_URL_ELT=
DAEMON_URL_LIT=
DAEMON_URL_PHO=
DAEMON_URL_UMO=
